		<!-- Workbench CSS -->
		<link rel="stylesheet" href="../../../workbench/workbench.desktop.main.css">
	<!-- !! VSCODE-CUSTOM-CSS-SESSION-ID 405b8153-877f-4eab-b761-42665a90f84d !! -->
<!-- !! VSCODE-CUSTOM-CSS-START !! -->
<!-- !! MINIWORLD-THEME-START !! -->
<style id="miniworld-theme-hub">
/* AUTO-GENERATED by MiniWorld Theme Hub 鈥?do not edit by hand */
/* scheme: glass-mini | button: chunky-block | sword: True */

/* ---- textures.css ---- */
/* textures disabled in glass redesign — kept for compatibility */


/* ---- icons.css ---- */
/* 默认不强制替换为像素图标（避免廉价感）。
   仅轻微统一活动栏视觉；如需像素图标可把 state.usePixelIcons 打开后扩展。 */

.monaco-workbench .activitybar .action-label.codicon {
  font-size: 22px !important;
  opacity: 0.92;
}

.monaco-workbench .activitybar .action-item.checked .action-label {
  opacity: 1;
}


/* ---- base.css ---- */
/* ============================================================
   MiniWorld Glass — 简洁毛玻璃 + 迷你世界轻点缀
   设计原则：少描边、不拉伸像素贴图、可读优先、Apple 式模糊玻璃
   ============================================================ */

:root {
  --mw-sky: #7BC8F6;
  --mw-grass: #78B833;
  --mw-orange: #E88C4D;
  --mw-wood: #8B5A2B;
  --mw-glass: rgba(255, 255, 255, 0.55);
  --mw-glass-strong: rgba(255, 252, 248, 0.72);
  --mw-glass-border: rgba(255, 255, 255, 0.65);
  --mw-line: rgba(123, 200, 246, 0.28);
  --mw-blur: blur(18px) saturate(1.35);
  --mw-radius: 12px;
}

/* ---- Global glass panels ---- */
.monaco-workbench .part.sidebar,
.monaco-workbench .part.auxiliarybar,
.monaco-workbench .part.panel,
.monaco-workbench .part.activitybar {
  backdrop-filter: var(--mw-blur) !important;
  -webkit-backdrop-filter: var(--mw-blur) !important;
  border: none !important;
  box-shadow: none !important;
}

.monaco-workbench .part.sidebar {
  background: rgba(243, 250, 255, 0.58) !important;
  border-right: 1px solid var(--mw-line) !important;
}

.monaco-workbench .part.auxiliarybar {
  background: rgba(255, 252, 250, 0.55) !important;
  border-left: 1px solid rgba(0, 0, 0, 0.06) !important;
}

.monaco-workbench .part.panel {
  background: rgba(247, 252, 255, 0.65) !important;
  border-top: 1px solid var(--mw-line) !important;
}

.monaco-workbench .part.activitybar {
  background: rgba(232, 246, 252, 0.55) !important;
  border-right: 1px solid var(--mw-line) !important;
}

/* ---- Title bar: soft sky wash, NO tiled pixel sky ---- */
.monaco-workbench .part.titlebar {
  background: linear-gradient(
    180deg,
    rgba(180, 225, 250, 0.85) 0%,
    rgba(230, 245, 255, 0.75) 100%
  ) !important;
  backdrop-filter: blur(12px) !important;
  -webkit-backdrop-filter: blur(12px) !important;
  border-bottom: 1px solid var(--mw-line) !important;
  box-shadow: none !important;
}

/* ---- Status bar: solid soft green, no grass tile ---- */
.monaco-workbench .part.statusbar {
  background: linear-gradient(90deg, #6faf2e 0%, #78B833 50%, #8bc93f 100%) !important;
  border-top: none !important;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.25) !important;
  font-weight: 500 !important;
}

/* ---- Editor frame: quiet ---- */
.monaco-workbench .part.editor > .content .editor-group-container {
  border: none !important;
  border-radius: 0 !important;
  margin: 0 !important;
  box-shadow: none !important;
  overflow: hidden !important;
}

.monaco-workbench .editor-group-container .title {
  background: rgba(232, 246, 252, 0.75) !important;
  backdrop-filter: blur(10px) !important;
  border-bottom: 1px solid var(--mw-line) !important;
}

/* Tabs — clean, single grass accent on active only */
.tabs-container > .tab {
  border: none !important;
  border-radius: 8px 8px 0 0 !important;
  margin: 0 2px !important;
  background: transparent !important;
  box-shadow: none !important;
}

.tabs-container > .tab.active {
  background: rgba(255, 255, 255, 0.85) !important;
  box-shadow: inset 0 2px 0 #78B833 !important;
  font-weight: 600 !important;
}

/* Pane headers — flat glass, no wood planks */
.monaco-workbench .pane-header,
.monaco-workbench .part.sidebar .pane-header,
.monaco-workbench .part.auxiliarybar .pane-header,
.monaco-workbench .composite.title {
  background: transparent !important;
  border-bottom: 1px solid var(--mw-line) !important;
  font-weight: 600 !important;
  text-shadow: none !important;
  box-shadow: none !important;
}

/* ---- Floating widgets: glass cards ---- */
.monaco-workbench .quick-input-widget,
.monaco-editor .suggest-widget,
.monaco-editor .parameter-hints-widget,
.monaco-editor .find-widget,
.monaco-editor .monaco-hover,
.monaco-workbench .notification-toast,
.monaco-workbench .dialog-widget {
  background: rgba(255, 255, 255, 0.82) !important;
  backdrop-filter: blur(20px) saturate(1.4) !important;
  -webkit-backdrop-filter: blur(20px) saturate(1.4) !important;
  border: 1px solid rgba(255, 255, 255, 0.7) !important;
  border-radius: var(--mw-radius) !important;
  box-shadow: 0 8px 32px rgba(43, 90, 120, 0.12) !important;
  overflow: hidden !important;
}

.monaco-workbench .quick-input-widget .quick-input-header {
  background: rgba(123, 200, 246, 0.15) !important;
  border-bottom: 1px solid var(--mw-line) !important;
}

/* Inputs */
.monaco-workbench .monaco-inputbox {
  border: 1px solid rgba(123, 200, 246, 0.4) !important;
  border-radius: 8px !important;
  background: rgba(255, 255, 255, 0.75) !important;
  box-shadow: none !important;
}

.monaco-workbench .monaco-inputbox.synthetic-focus,
.monaco-workbench .monaco-inputbox.focus {
  border-color: rgba(120, 184, 51, 0.7) !important;
  box-shadow: 0 0 0 3px rgba(120, 184, 51, 0.15) !important;
}

/* Scrollbar — slim soft orange thumb, no block texture */
.monaco-scrollable-element > .scrollbar > .slider {
  border-radius: 999px !important;
  border: none !important;
  background: rgba(232, 140, 77, 0.45) !important;
  box-shadow: none !important;
  opacity: 1 !important;
}

.monaco-scrollable-element > .scrollbar > .slider:hover {
  background: rgba(232, 140, 77, 0.7) !important;
}

/* Lists */
.monaco-workbench .monaco-list .monaco-list-row {
  border-radius: 8px !important;
  margin: 1px 6px !important;
}

.monaco-workbench .monaco-list .monaco-list-row.selected,
.monaco-workbench .monaco-list .monaco-list-row.focused {
  outline: none !important;
  box-shadow: none !important;
  background: rgba(120, 184, 51, 0.18) !important;
}

.monaco-workbench .monaco-list .monaco-list-row:hover {
  outline: none !important;
  background: rgba(123, 200, 246, 0.14) !important;
}

/* Buttons — soft rounded, Mini World accent, no pixel borders */
.monaco-workbench .monaco-button,
.monaco-workbench .monaco-text-button,
.monaco-workbench a.monaco-button {
  border-radius: 10px !important;
  border: none !important;
  box-shadow: 0 1px 2px rgba(90, 56, 24, 0.12) !important;
  font-weight: 600 !important;
  min-height: 28px !important;
  background-image: none !important;
  transform: none !important;
  image-rendering: auto !important;
}

.monaco-workbench .monaco-button:hover,
.monaco-workbench .monaco-text-button:hover {
  filter: brightness(1.05) !important;
  transform: none !important;
  box-shadow: 0 2px 8px rgba(120, 184, 51, 0.25) !important;
}

.monaco-workbench .monaco-button:active,
.monaco-workbench .monaco-text-button:active {
  transform: none !important;
}

/* Keep code readable — no blur on editor canvas */
.monaco-workbench .monaco-editor,
.monaco-workbench .part.editor .editor-container {
  filter: none !important;
  backdrop-filter: none !important;
}

.monaco-workbench .rendered-markdown,
.monaco-workbench .markdown-root {
  text-shadow: none !important;
  filter: none !important;
}

.monaco-editor .minimap {
  border-left: 1px solid var(--mw-line) !important;
}

.monaco-workbench .monaco-sash.vertical:before,
.monaco-workbench .monaco-sash.horizontal:before {
  background: rgba(120, 184, 51, 0.35) !important;
}

.monaco-workbench .command-center,
.monaco-workbench .titlebar-center .command-center-center {
  border: 1px solid var(--mw-line) !important;
  border-radius: 10px !important;
  background: rgba(255, 255, 255, 0.45) !important;
  backdrop-filter: blur(8px) !important;
  box-shadow: none !important;
}

.monaco-workbench .editor-group-container.empty {
  border: none !important;
  background: transparent !important;
}


/* ---- windows.css ---- */
/* Extra chrome — keep minimal */

.monaco-editor .peekview-widget {
  border: 1px solid rgba(120, 184, 51, 0.35) !important;
  border-radius: 12px !important;
  overflow: hidden !important;
  box-shadow: 0 8px 28px rgba(43, 90, 120, 0.12) !important;
}

.monaco-workbench .monaco-toolbar .action-label {
  border-radius: 8px !important;
}

.monaco-workbench .monaco-toolbar .action-item:hover .action-label {
  box-shadow: none !important;
  background: rgba(120, 184, 51, 0.15) !important;
}

.monaco-workbench .notifications-list-container .notification-list-item {
  border-radius: 12px !important;
  border: 1px solid rgba(255, 255, 255, 0.6) !important;
  box-shadow: 0 6px 24px rgba(43, 90, 120, 0.1) !important;
}


/* ---- chat.css ---- */
/* Chat / Agent — 减少嵌套卡片，恢复清晰层次 */

/* Kill decorative pseudo strips */
.monaco-workbench .part.auxiliarybar::before,
.monaco-workbench .part.sidebar::before {
  display: none !important;
  content: none !important;
}

/* Shell: flat glass, single subtle edge — no stacked frames */
.monaco-workbench .part.auxiliarybar {
  background: rgba(255, 252, 250, 0.55) !important;
  backdrop-filter: blur(16px) saturate(1.2) !important;
  -webkit-backdrop-filter: blur(16px) saturate(1.2) !important;
  border-left: 1px solid rgba(0, 0, 0, 0.06) !important;
  box-shadow: none !important;
}

.monaco-workbench .part.auxiliarybar .content {
  background: transparent !important;
}

.monaco-workbench .part.auxiliarybar .pane-header,
.monaco-workbench .part.auxiliarybar .composite.title {
  background: transparent !important;
  border-bottom: 1px solid rgba(0, 0, 0, 0.06) !important;
  box-shadow: none !important;
  margin-top: 0 !important;
  font-weight: 600 !important;
}

/* ========== Flatten nested cards ==========
   Cursor often wraps: outer peach → white → inner peach.
   Force intermediate wrappers to be transparent / borderless. */

.monaco-workbench .part.auxiliarybar [class*="composer"] > div,
.monaco-workbench .part.auxiliarybar [class*="agent"] > div,
.monaco-workbench .part.auxiliarybar [class*="chat"] > div,
.monaco-workbench .part.auxiliarybar [class*="scroll"] > div,
.monaco-workbench .part.auxiliarybar [class*="messages"] > div,
.monaco-workbench .part.auxiliarybar [class*="thread"] > div {
  background-color: transparent !important;
  border: none !important;
  box-shadow: none !important;
  outline: none !important;
}

/* Pinned / sticky prompt card — ONE surface only */
.monaco-workbench .part.auxiliarybar [class*="pinned"],
.monaco-workbench .part.auxiliarybar [class*="sticky"],
.monaco-workbench .part.auxiliarybar [class*="context-card"],
.monaco-workbench .part.auxiliarybar [class*="ContextCard"],
.monaco-workbench .part.auxiliarybar [class*="selected-context"],
.monaco-workbench .part.auxiliarybar [class*="bubble"],
.monaco-workbench .part.auxiliarybar [class*="message-bubble"],
.monaco-workbench .part.auxiliarybar [class*="ui-message"],
.monaco-workbench [class*="composer-message"],
.monaco-workbench [class*="human-message"],
.monaco-workbench [class*="user-message"],
.monaco-workbench [class*="ai-message"],
.monaco-workbench [class*="assistant-message"] {
  background: rgba(255, 255, 255, 0.72) !important;
  backdrop-filter: blur(8px) !important;
  border: 1px solid rgba(0, 0, 0, 0.06) !important;
  border-radius: 12px !important;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04) !important;
  margin: 6px 10px !important;
  padding: 10px 12px !important;
}

/* Nested children inside a card must not look like another card */
.monaco-workbench .part.auxiliarybar [class*="bubble"] *,
.monaco-workbench .part.auxiliarybar [class*="message"] *,
.monaco-workbench .part.auxiliarybar [class*="pinned"] *,
.monaco-workbench .part.auxiliarybar [class*="sticky"] *,
.monaco-workbench [class*="human-message"] *,
.monaco-workbench [class*="composer-message"] * {
  /* don't blanket * — too aggressive; handled by specific rules below */
}

.monaco-workbench .part.auxiliarybar [class*="bubble"] > div,
.monaco-workbench .part.auxiliarybar [class*="message"] > div,
.monaco-workbench .part.auxiliarybar [class*="pinned"] > div,
.monaco-workbench .part.auxiliarybar [class*="sticky"] > div,
.monaco-workbench [class*="human-message"] > div,
.monaco-workbench [class*="composer-message"] > div,
.monaco-workbench [class*="ai-message"] > div {
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
  border-radius: 0 !important;
  margin: 0 !important;
  padding: 0 !important;
}

/* Soft role tint without extra boxes */
.monaco-workbench [class*="human-message"],
.monaco-workbench [class*="user-message"] {
  background: rgba(255, 245, 238, 0.9) !important;
  border-color: rgba(232, 140, 77, 0.18) !important;
}

.monaco-workbench [class*="ai-message"],
.monaco-workbench [class*="assistant-message"] {
  background: rgba(255, 255, 255, 0.78) !important;
  border-color: rgba(120, 184, 51, 0.15) !important;
}

/* Code: one quiet block */
.monaco-workbench .part.auxiliarybar pre,
.monaco-workbench .part.auxiliarybar .monaco-codeblock,
.monaco-workbench .rendered-markdown pre,
.monaco-workbench .markdown-root pre {
  border: 1px solid rgba(0, 0, 0, 0.06) !important;
  border-radius: 8px !important;
  box-shadow: none !important;
  background: rgba(248, 250, 252, 0.95) !important;
  margin: 8px 0 !important;
  padding: 10px 12px !important;
}

.monaco-workbench .part.auxiliarybar code,
.monaco-workbench .rendered-markdown code {
  border: none !important;
  border-radius: 4px !important;
  background: rgba(120, 184, 51, 0.1) !important;
}

/* Composer input — single field, no double frame */
.monaco-workbench .interactive-input-editor,
.monaco-workbench .chat-input-container,
.monaco-workbench [class*="chat-input"],
.monaco-workbench [class*="composer-input"],
.monaco-workbench .composer-input-container,
.monaco-workbench .aislash-editor-input,
.monaco-workbench [class*="PromptInput"],
.monaco-workbench [class*="prompt-input"] {
  border: 1px solid rgba(0, 0, 0, 0.08) !important;
  border-radius: 12px !important;
  background: rgba(255, 255, 255, 0.88) !important;
  backdrop-filter: blur(10px) !important;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04) !important;
  margin: 8px 10px 12px !important;
  padding: 4px 6px !important;
}

/* Kill nested borders inside input wrapper */
.monaco-workbench [class*="composer-input"] > div,
.monaco-workbench [class*="chat-input"] > div,
.monaco-workbench .composer-input-container > div,
.monaco-workbench .interactive-input-editor > div {
  border: none !important;
  box-shadow: none !important;
  background: transparent !important;
}

.monaco-workbench .interactive-input-editor:focus-within,
.monaco-workbench [class*="chat-input"]:focus-within,
.monaco-workbench [class*="composer-input"]:focus-within {
  border-color: rgba(120, 184, 51, 0.45) !important;
  box-shadow: 0 0 0 3px rgba(120, 184, 51, 0.1) !important;
}

/* Footer toolbar: hairline only */
.monaco-workbench .part.auxiliarybar [class*="composer"] [class*="bottom"],
.monaco-workbench .part.auxiliarybar [class*="input-area"],
.monaco-workbench .part.auxiliarybar [class*="prompt-form"] {
  border-top: 1px solid rgba(0, 0, 0, 0.05) !important;
  background: transparent !important;
  padding-top: 4px !important;
  padding-bottom: 4px !important;
}

.monaco-workbench .part.auxiliarybar [class*="chip"],
.monaco-workbench .part.auxiliarybar [class*="pill"] {
  border-radius: 999px !important;
  border: 1px solid rgba(0, 0, 0, 0.08) !important;
  background: rgba(255, 255, 255, 0.65) !important;
}

.monaco-workbench .part.auxiliarybar button,
.monaco-workbench [class*="composer"] button {
  border-radius: 8px !important;
}

.monaco-workbench .part.auxiliarybar .rendered-markdown p,
.monaco-workbench .part.auxiliarybar .markdown-root p {
  margin: 0.45em 0 !important;
  line-height: 1.55 !important;
}

/* Section separators instead of boxes */
.monaco-workbench .part.auxiliarybar [class*="divider"],
.monaco-workbench .part.auxiliarybar hr {
  border: none !important;
  border-top: 1px solid rgba(0, 0, 0, 0.05) !important;
  background: transparent !important;
  height: 0 !important;
  margin: 8px 12px !important;
}


/* ---- chunky-block.css ---- */
/* Soft glass buttons — no pixel block borders */
.monaco-workbench .monaco-button,
.monaco-workbench .monaco-text-button,
.monaco-workbench a.monaco-button,
.monaco-workbench .monaco-button-dropdown > .monaco-button {
  border-radius: 10px !important;
  border: none !important;
  background-image: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.28),
    rgba(255, 255, 255, 0)
  ) !important;
  box-shadow: 0 1px 3px rgba(90, 56, 24, 0.14) !important;
  font-weight: 600 !important;
  image-rendering: auto !important;
  min-height: 28px !important;
}

.monaco-workbench .monaco-button:hover,
.monaco-workbench .monaco-text-button:hover {
  filter: brightness(1.06) !important;
  box-shadow: 0 3px 10px rgba(232, 140, 77, 0.28) !important;
}

.monaco-workbench .monaco-button.secondary,
.monaco-workbench .monaco-text-button.secondary {
  box-shadow: 0 1px 2px rgba(46, 139, 200, 0.15) !important;
}


/* ---- cursor.css ---- */
/* Official Mini World energy sword from user pack — tip-left, 32px, hotspot (1,1) */
:root { --mw-cursor-sword: url(data:image/png;base64,) 1 1, default; }

.monaco-workbench,
.monaco-workbench .part,
.monaco-workbench .monaco-button,
.monaco-workbench .action-label,
.monaco-workbench .monaco-list-row,
.monaco-workbench .tab,
.monaco-workbench .pane-header,
.monaco-workbench .composite,
.monaco-workbench .scrollbar,
.monaco-workbench a,
.monaco-workbench .codicon,
.monaco-editor .view-lines,
.monaco-editor .view-line,
.monaco-workbench textarea,
.monaco-workbench input,
.monaco-workbench .inputarea,
.monaco-mouse-cursor-text {
  cursor: var(--mw-cursor-sword) !important;
}


</style>
<!-- !! MINIWORLD-THEME-END !! -->
<!-- !! VSCODE-CUSTOM-CSS-END !! -->
</head>

	<body aria-label="">
	</body>

	<!-- Startup (do not modify order of script tags!) -->
	<script src="./workbench.js" type="module"></script>
