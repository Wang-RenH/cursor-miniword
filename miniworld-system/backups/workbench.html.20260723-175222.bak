/* ---- base.css ---- */
/* MiniWorld Theme Hub - immersive pixel UI (clarity-first) */
:root {
  --mw-sky: #7BC8F6;
  --mw-grass: #78B833;
  --mw-grass-dark: #5FA825;
  --mw-orange: #E88C4D;
  --mw-brick: #A54331;
  --mw-wood: #8B5A2B;
  --mw-wood-dark: #5A3818;
  --mw-cream: #FFF9F0;
  --mw-radius: 10px;
  --mw-gap: 10px;
}

/* Crisp pixel tiles */
.monaco-workbench .part.activitybar,
.monaco-workbench .part.sidebar .pane-header,
.monaco-workbench .part.auxiliarybar .pane-header,
.monaco-workbench .part.statusbar,
.monaco-workbench .part.titlebar,
.mw-pixel {
  image-rendering: pixelated;
  image-rendering: crisp-edges;
}

/* ========== Activity Bar: stacked grass blocks ========== */
.monaco-workbench .part.activitybar {
  border-right: none !important;
  background-image:
    linear-gradient(90deg, rgba(255,255,255,0.12), transparent 40%),
    var(--mw-tex-grass-block) !important;
  background-size: auto, 32px 48px !important;
  background-repeat: no-repeat, repeat-y !important;
  background-position: 0 0, center top !important;
  box-shadow: inset -3px 0 0 rgba(90, 56, 24, 0.35) !important;
}

/* ========== Title bar: sky strip ========== */
.monaco-workbench .part.titlebar {
  background-image:
    linear-gradient(180deg, rgba(255,255,255,0.25), rgba(255,255,255,0)),
    var(--mw-tex-sky) !important;
  background-size: auto, 256px 32px !important;
  background-repeat: no-repeat, repeat-x !important;
  background-position: 0 0, left center !important;
  border-bottom: none !important;
  box-shadow: inset 0 -4px 0 rgba(120, 184, 51, 0.85) !important;
}

/* ========== Sidebar: wood header + clean body ========== */
.monaco-workbench .part.sidebar {
  border-right: 4px solid transparent !important;
  border-image: var(--mw-tex-wood) 8 stretch !important;
  box-shadow: none !important;
}

.monaco-workbench .part.sidebar .pane-header,
.monaco-workbench .pane-header {
  background-image: var(--mw-tex-wood) !important;
  background-size: 128px 32px !important;
  background-repeat: repeat-x !important;
  border-bottom: 3px solid rgba(90, 56, 24, 0.45) !important;
  font-weight: 700 !important;
  text-shadow: 0 1px 0 rgba(255, 240, 220, 0.35) !important;
}

.monaco-workbench .sidebar .title-label h2,
.monaco-workbench .part.sidebar .composite.title {
  font-weight: 800 !important;
}

/* ========== Editor group: soft stone frame, not busy ========== */
.monaco-workbench .part.editor > .content .editor-group-container {
  border: 3px solid transparent !important;
  border-image: var(--mw-tex-stone) 4 stretch !important;
  border-radius: 0 !important;
  overflow: hidden !important;
  box-shadow: none !important;
  margin: 3px !important;
}

.tabs-container > .tab {
  border-radius: 0 !important;
  margin: 0 1px !important;
  border: none !important;
  background-image: linear-gradient(180deg, rgba(255,255,255,0.35), transparent) !important;
}

.tabs-container > .tab.active {
  box-shadow: inset 0 4px 0 transparent !important;
  background-image:
    var(--mw-tex-grass),
    linear-gradient(180deg, rgba(255,255,255,0.5), rgba(255,255,255,0.1)) !important;
  background-size: 64px 16px, auto !important;
  background-repeat: repeat-x, no-repeat !important;
  background-position: top, center !important;
  font-weight: 700 !important;
}

/* ========== Bottom panel ========== */
.monaco-workbench .part.panel {
  border-top: 4px solid transparent !important;
  border-image: var(--mw-tex-wood) 6 stretch !important;
  box-shadow: none !important;
}

/* ========== Status bar: grass top strip ========== */
.monaco-workbench .part.statusbar {
  border-top: none !important;
  background-image:
    var(--mw-tex-grass),
    linear-gradient(180deg, rgba(255,255,255,0.2), transparent) !important;
  background-size: 64px 12px, auto !important;
  background-repeat: repeat-x, no-repeat !important;
  background-position: top, center !important;
  box-shadow: inset 0 12px 0 rgba(0,0,0,0.08) !important;
  font-weight: 600 !important;
}

/* ========== Scrollbars: orange block thumb ========== */
.monaco-scrollable-element > .scrollbar > .slider {
  border-radius: 2px !important;
  border: none !important;
  background-image: var(--mw-tex-orange) !important;
  background-size: 16px 16px !important;
  background-repeat: repeat !important;
  box-shadow: none !important;
  opacity: 0.85 !important;
}

/* ========== Widgets: wood frame, single clear edge ========== */
.monaco-editor .suggest-widget,
.monaco-editor .parameter-hints-widget,
.monaco-workbench .quick-input-widget {
  border: 4px solid transparent !important;
  border-image: var(--mw-tex-wood) 8 stretch !important;
  border-radius: 0 !important;
  box-shadow: 0 6px 0 rgba(90, 56, 24, 0.25) !important;
  overflow: hidden !important;
}

.monaco-workbench .quick-input-widget .quick-input-header {
  background-image: var(--mw-tex-grass) !important;
  background-size: 64px 16px !important;
  background-repeat: repeat-x !important;
  border-bottom: 2px solid rgba(90, 56, 24, 0.35) !important;
}

.notification-toast,
.notifications-list-container .notification-list-item,
.monaco-workbench .dialog-widget,
.monaco-workbench .monaco-dialog-box {
  border: 4px solid transparent !important;
  border-image: var(--mw-tex-wood) 8 stretch !important;
  border-radius: 0 !important;
  box-shadow: 0 5px 0 rgba(90, 56, 24, 0.22) !important;
}

/* Inputs */
.monaco-workbench .monaco-inputbox {
  border: 2px solid rgba(139, 90, 43, 0.5) !important;
  border-radius: 2px !important;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.5) !important;
}

/* Keep code crisp */
.monaco-workbench .part.editor,
.monaco-workbench .monaco-editor,
.monaco-workbench .part.auxiliarybar,
.monaco-workbench .part.sidebar,
.monaco-workbench .part.panel {
  filter: none !important;
  backdrop-filter: none !important;
}

.monaco-workbench .rendered-markdown,
.monaco-workbench .markdown-root {
  text-shadow: none !important;
  filter: none !important;
}

.monaco-editor .minimap {
  border-left: 2px solid rgba(139, 90, 43, 0.2) !important;
}

.monaco-workbench .monaco-sash.vertical:before,
.monaco-workbench .monaco-sash.horizontal:before {
  background: rgba(120, 184, 51, 0.65) !important;
}


/* ---- windows.css ---- */
/* Lists / find / hover — pixel accents, keep clean */

.monaco-workbench .monaco-list .monaco-list-row {
  border-radius: 2px !important;
  margin: 1px 6px !important;
}

.monaco-workbench .monaco-list .monaco-list-row.selected,
.monaco-workbench .monaco-list .monaco-list-row.focused {
  outline: none !important;
  box-shadow: inset 3px 0 0 #78B833 !important;
}

.monaco-workbench .monaco-list .monaco-list-row:hover {
  outline: none !important;
  background-image: linear-gradient(90deg, rgba(123, 200, 246, 0.18), transparent) !important;
}

.monaco-editor .find-widget {
  border: 4px solid transparent !important;
  border-image: var(--mw-tex-wood) 8 stretch !important;
  border-radius: 0 !important;
  box-shadow: 0 4px 0 rgba(90, 56, 24, 0.2) !important;
}

.monaco-editor .peekview-widget {
  border: 3px solid transparent !important;
  border-image: var(--mw-tex-grass) 4 stretch !important;
  border-radius: 0 !important;
  overflow: hidden !important;
}

.monaco-editor .monaco-hover {
  border: 3px solid transparent !important;
  border-image: var(--mw-tex-wood) 6 stretch !important;
  border-radius: 0 !important;
  box-shadow: 0 3px 0 rgba(90, 56, 24, 0.18) !important;
}

.monaco-workbench .command-center,
.monaco-workbench .titlebar-center .command-center-center {
  border: 3px solid transparent !important;
  border-image: var(--mw-tex-wood) 6 stretch !important;
  border-radius: 0 !important;
  box-shadow: none !important;
}

.monaco-workbench .monaco-toolbar .action-label {
  border-radius: 2px !important;
}

.monaco-workbench .monaco-toolbar .action-item:hover .action-label {
  box-shadow: inset 0 0 0 2px rgba(120, 184, 51, 0.55) !important;
  background-image: linear-gradient(180deg, rgba(168, 217, 106, 0.25), transparent) !important;
}

.monaco-workbench .editor-group-container.empty {
  border: 3px dashed rgba(120, 184, 51, 0.45) !important;
  border-radius: 0 !important;
  background-image:
    linear-gradient(rgba(255,255,255,0.4), rgba(255,255,255,0.4)),
    var(--mw-tex-grass-block) !important;
  background-size: auto, 48px 72px !important;
  background-repeat: no-repeat, repeat !important;
  background-position: center, center !important;
  opacity: 0.95;
}


/* ---- chat.css ---- */
/* Chat / Agent — pixel MiniWorld, clean & spacious (not crowded) */

/* Auxiliary bar shell: grass roof + wood sides, airy interior */
.monaco-workbench .part.auxiliarybar {
  border-left: 4px solid transparent !important;
  border-image: var(--mw-tex-wood) 8 stretch !important;
  box-shadow: none !important;
  position: relative !important;
}

/* Grass turf along the top — the signature MiniWorld strip */
.monaco-workbench .part.auxiliarybar::before {
  content: "";
  pointer-events: none;
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 14px;
  z-index: 30;
  background-image: var(--mw-tex-grass);
  background-size: 64px 14px;
  background-repeat: repeat-x;
  image-rendering: pixelated;
  box-shadow: 0 2px 0 rgba(90, 56, 24, 0.25);
}

/* Soft cream wash so text stays clean over wallpaper */
.monaco-workbench .part.auxiliarybar .content {
  background-image: linear-gradient(
    180deg,
    rgba(255, 252, 247, 0.72) 0%,
    rgba(255, 252, 247, 0.55) 100%
  ) !important;
}

.monaco-workbench .part.auxiliarybar .pane-header,
.monaco-workbench .part.auxiliarybar .composite.title {
  margin-top: 10px !important;
  background-image: var(--mw-tex-wood) !important;
  background-size: 128px 28px !important;
  background-repeat: repeat-x !important;
  border-bottom: 2px solid rgba(90, 56, 24, 0.35) !important;
  font-weight: 800 !important;
  letter-spacing: 0.2px !important;
}

/* ---- Breathing room: messages ---- */
.monaco-workbench .part.auxiliarybar [class*="bubble"],
.monaco-workbench .part.auxiliarybar [class*="message-bubble"],
.monaco-workbench .part.auxiliarybar [class*="ui-message"],
.monaco-workbench [class*="composer-message"],
.monaco-workbench [class*="human-message"],
.monaco-workbench [class*="ai-message"] {
  border: none !important;
  border-radius: 4px !important;
  box-shadow: none !important;
  margin: 10px 14px !important;
  padding: 12px 14px !important;
  background-color: rgba(255, 255, 255, 0.78) !important;
}

/* Only lightly mark AI vs user with a grass/wood accent bar */
.monaco-workbench [class*="human-message"],
.monaco-workbench [class*="user-message"] {
  box-shadow: inset 4px 0 0 #E88C4D !important;
  background-color: rgba(255, 248, 240, 0.88) !important;
}

.monaco-workbench [class*="ai-message"],
.monaco-workbench [class*="assistant-message"],
.monaco-workbench [class*="composer-message"]:not([class*="human"]) {
  box-shadow: inset 4px 0 0 #78B833 !important;
}

/* Code blocks = stone tablet, not heavy frames everywhere */
.monaco-workbench .part.auxiliarybar pre,
.monaco-workbench .part.auxiliarybar .monaco-codeblock,
.monaco-workbench .rendered-markdown pre,
.monaco-workbench .markdown-root pre {
  border: 3px solid transparent !important;
  border-image: var(--mw-tex-stone) 4 stretch !important;
  border-radius: 0 !important;
  box-shadow: none !important;
  background-color: rgba(255, 252, 247, 0.95) !important;
  margin: 10px 0 !important;
  padding: 12px !important;
}

.monaco-workbench .part.auxiliarybar code,
.monaco-workbench .rendered-markdown code {
  border-radius: 2px !important;
  border: none !important;
  background-color: rgba(123, 200, 246, 0.18) !important;
}

/* ---- Composer input: one wooden sign, not nested borders ---- */
.monaco-workbench .interactive-input-editor,
.monaco-workbench .chat-input-container,
.monaco-workbench [class*="chat-input"],
.monaco-workbench [class*="composer-input"],
.monaco-workbench .composer-input-container,
.monaco-workbench .aislash-editor-input,
.monaco-workbench [class*="PromptInput"],
.monaco-workbench [class*="prompt-input"] {
  border: 4px solid transparent !important;
  border-image: var(--mw-tex-wood) 8 stretch !important;
  border-radius: 0 !important;
  background-color: rgba(255, 249, 240, 0.96) !important;
  box-shadow: 0 4px 0 rgba(90, 56, 24, 0.2) !important;
  margin: 12px 14px 16px !important;
  padding: 4px !important;
}

.monaco-workbench .interactive-input-editor:focus-within,
.monaco-workbench [class*="chat-input"]:focus-within,
.monaco-workbench [class*="composer-input"]:focus-within {
  border-image: var(--mw-tex-grass) 4 stretch !important;
  box-shadow: 0 4px 0 rgba(95, 168, 37, 0.35) !important;
}

/* Footer toolbar: light wood strip, more padding */
.monaco-workbench .part.auxiliarybar [class*="composer"] [class*="bottom"],
.monaco-workbench .part.auxiliarybar [class*="input-area"],
.monaco-workbench .part.auxiliarybar [class*="prompt-form"] {
  border-top: 3px solid transparent !important;
  border-image: var(--mw-tex-wood) 6 stretch !important;
  background-color: rgba(255, 248, 235, 0.35) !important;
  padding-top: 8px !important;
  padding-bottom: 8px !important;
}

/* Chips / mode pickers: orange mini-blocks, not busy pills */
.monaco-workbench .part.auxiliarybar [class*="chip"],
.monaco-workbench .part.auxiliarybar [class*="pill"] {
  border-radius: 2px !important;
  border: 2px solid rgba(90, 56, 24, 0.35) !important;
  background-image: linear-gradient(180deg, rgba(255,255,255,0.35), transparent) !important;
}

.monaco-workbench .part.auxiliarybar button,
.monaco-workbench [class*="composer"] button,
.monaco-workbench [class*="chat"] button {
  border-radius: 2px !important;
}

/* Markdown readability + spacing */
.monaco-workbench .part.auxiliarybar .rendered-markdown p,
.monaco-workbench .part.auxiliarybar .markdown-root p {
  margin: 0.55em 0 !important;
  line-height: 1.55 !important;
}

.monaco-workbench .part.auxiliarybar .rendered-markdown ul,
.monaco-workbench .part.auxiliarybar .rendered-markdown ol {
  margin: 0.45em 0 0.45em 1.1em !important;
  padding-left: 0.4em !important;
}


/* ---- chunky-block.css ---- */
/* Button skin: chunky-block — real orange/grass pixel blocks */
.monaco-workbench .monaco-button,
.monaco-workbench .monaco-text-button,
.monaco-workbench a.monaco-button,
.monaco-workbench .monaco-button-dropdown > .monaco-button {
  border-radius: 0 !important;
  border: 3px solid transparent !important;
  border-image: var(--mw-tex-orange) 4 stretch !important;
  background-image:
    linear-gradient(180deg, rgba(255,255,255,0.28), transparent 45%, rgba(0,0,0,0.12)),
    var(--mw-tex-orange) !important;
  background-size: auto, 32px 32px !important;
  background-repeat: no-repeat, repeat !important;
  box-shadow: 0 4px 0 rgba(90, 50, 20, 0.35) !important;
  font-weight: 800 !important;
  letter-spacing: 0.3px !important;
  image-rendering: pixelated !important;
  min-height: 30px !important;
  transition: transform 0.08s ease, filter 0.08s ease !important;
}

.monaco-workbench .monaco-button:hover,
.monaco-workbench .monaco-text-button:hover,
.monaco-workbench a.monaco-button:hover {
  filter: brightness(1.08) !important;
  transform: translateY(-2px) !important;
  border-image: var(--mw-tex-grass) 4 stretch !important;
}

.monaco-workbench .monaco-button:active,
.monaco-workbench .monaco-text-button:active {
  transform: translateY(2px) !important;
  box-shadow: 0 1px 0 rgba(90, 50, 20, 0.3) !important;
}

.monaco-workbench .monaco-button.secondary,
.monaco-workbench .monaco-text-button.secondary {
  border-image: var(--mw-tex-grass) 4 stretch !important;
  background-image:
    linear-gradient(180deg, rgba(255,255,255,0.3), transparent 50%),
    var(--mw-tex-grass) !important;
  background-size: auto, 32px 16px !important;
}

.monaco-workbench .monaco-custom-toggle,
.monaco-workbench .monaco-checkbox {
  border-radius: 0 !important;
  border-width: 2px !important;
}



</style>
<!-- !! MINIWORLD-THEME-END !! -->
<!-- !! VSCODE-CUSTOM-CSS-END !! -->
</head>

	<body aria-label="">
	</body>

	<!-- Startup (do not modify order of script tags!) -->
	<script src="./workbench.js" type="module"></script>
</html>
