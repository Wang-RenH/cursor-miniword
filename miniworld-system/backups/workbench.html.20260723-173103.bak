		<!-- Workbench CSS -->
		<link rel="stylesheet" href="../../../workbench/workbench.desktop.main.css">
	<!-- !! VSCODE-CUSTOM-CSS-SESSION-ID dad63cd1-93f2-443b-a204-2db28aee0976 !! -->
<!-- !! VSCODE-CUSTOM-CSS-START !! -->
<!-- !! MINIWORLD-THEME-START !! -->
<style id="miniworld-theme-hub">
/* AUTO-GENERATED by MiniWorld Theme Hub 鈥?do not edit by hand */
/* scheme: sunny-town | button: chunky-block */

/* ---- base.css ---- */
/* MiniWorld Theme Hub - immersive UI (clarity-first, no blur) */
:root {
  --mw-sky: #7BC8F6;
  --mw-grass: #78B833;
  --mw-grass-dark: #5FA825;
  --mw-orange: #E88C4D;
  --mw-brick: #A54331;
  --mw-wood: #8B5A2B;
  --mw-wood-dark: #5A3818;
  --mw-cream: #FFF9F0;
  --mw-cream-solid: #FFF8EE;
  --mw-radius: 10px;
  --mw-border: 3px solid rgba(139, 90, 43, 0.65);
  --mw-block-shadow: inset 0 2px 0 rgba(255, 255, 255, 0.45),
    inset 0 -3px 0 rgba(0, 0, 0, 0.12),
    0 4px 0 rgba(90, 56, 24, 0.28);
}

/* ========== Activity Bar: toy block strip ========== */
.monaco-workbench .part.activitybar {
  border-right: 3px solid rgba(139, 90, 43, 0.45) !important;
  box-shadow: inset -2px 0 0 rgba(255, 255, 255, 0.35) !important;
}

.monaco-workbench .activitybar .action-item.checked .action-label,
.monaco-workbench .activitybar .action-item.checked {
  border-left: 3px solid var(--mw-grass) !important;
}

/* ========== Sidebar: wooden panel ========== */
.monaco-workbench .part.sidebar {
  border-right: var(--mw-border) !important;
  box-shadow: inset 0 3px 0 rgba(120, 184, 51, 0.55) !important;
}

.monaco-workbench .part.sidebar .pane-header,
.monaco-workbench .pane-header {
  border-bottom: 2px solid rgba(139, 90, 43, 0.35) !important;
  background-image: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.35) 0%,
    rgba(255, 255, 255, 0) 100%
  ) !important;
  font-weight: 700 !important;
}

.monaco-workbench .part.sidebar .composite.title,
.monaco-workbench .sidebar .title-label h2 {
  font-weight: 800 !important;
  letter-spacing: 0.3px !important;
}

/* ========== Title bar ========== */
.monaco-workbench .part.titlebar {
  box-shadow: inset 0 -3px 0 rgba(120, 184, 51, 0.5) !important;
  border-bottom: 2px solid rgba(139, 90, 43, 0.35) !important;
}

/* ========== Editor group frame ========== */
.monaco-workbench .part.editor > .content .editor-group-container {
  border: 2px solid rgba(123, 200, 246, 0.45) !important;
  border-radius: 8px !important;
  overflow: hidden !important;
  box-shadow: 0 3px 0 rgba(139, 90, 43, 0.12) !important;
  margin: 2px !important;
}

.monaco-workbench .editor-group-container .title {
  border-bottom: 2px solid rgba(139, 90, 43, 0.25) !important;
}

.tabs-container > .tab {
  border-radius: 8px 8px 0 0 !important;
  margin: 0 2px !important;
  border: 1px solid rgba(139, 90, 43, 0.2) !important;
  border-bottom: none !important;
}

.tabs-container > .tab.active {
  box-shadow: inset 0 3px 0 var(--mw-grass) !important;
  border-color: rgba(139, 90, 43, 0.45) !important;
  font-weight: 700 !important;
}

/* ========== Bottom panel ========== */
.monaco-workbench .part.panel {
  border-top: var(--mw-border) !important;
  box-shadow: inset 0 3px 0 rgba(232, 140, 77, 0.35) !important;
}

.monaco-workbench .panel .composite.title {
  border-bottom: 2px solid rgba(139, 90, 43, 0.25) !important;
}

/* ========== Status bar: grass block ========== */
.monaco-workbench .part.statusbar {
  border-top: 3px solid var(--mw-wood-dark) !important;
  box-shadow: inset 0 3px 0 rgba(255, 255, 255, 0.35) !important;
  font-weight: 600 !important;
}

/* ========== Auxiliary bar / Chat / Agent ========== */
.monaco-workbench .part.auxiliarybar {
  border-left: 4px solid var(--mw-wood) !important;
  box-shadow:
    inset 4px 0 0 rgba(120, 184, 51, 0.45),
    inset 0 3px 0 rgba(255, 236, 200, 0.4) !important;
}

.monaco-workbench .part.auxiliarybar .pane-header,
.monaco-workbench .part.auxiliarybar .composite.title {
  border-bottom: 2px solid rgba(139, 90, 43, 0.4) !important;
  font-weight: 800 !important;
}

/* Chat bubbles / markdown cards */
.monaco-workbench .part.auxiliarybar .rendered-markdown,
.monaco-workbench .markdown-root,
.monaco-workbench [class*="composer"] .anysphere-markdown-container,
.monaco-workbench [class*="agent"] [class*="message"],
.monaco-workbench [class*="chat"] [class*="message"] {
  border-radius: 10px !important;
}

/* Message cards look like wooden signs */
.monaco-workbench .part.auxiliarybar [class*="bubble"],
.monaco-workbench .part.auxiliarybar [class*="message-bubble"],
.monaco-workbench .part.auxiliarybar [class*="ui-message"],
.monaco-workbench [class*="composer-message"],
.monaco-workbench [class*="human-message"],
.monaco-workbench [class*="ai-message"] {
  border: 2px solid rgba(139, 90, 43, 0.35) !important;
  border-radius: 12px !important;
  box-shadow: 0 3px 0 rgba(90, 56, 24, 0.12) !important;
}

/* Composer / chat input = wooden signboard */
.monaco-workbench .interactive-input-editor,
.monaco-workbench .chat-input-container,
.monaco-workbench [class*="chat-input"],
.monaco-workbench [class*="composer-input"],
.monaco-workbench .composer-input-container,
.monaco-workbench .aislash-editor-input,
.monaco-workbench [class*="PromptInput"],
.monaco-workbench [class*="prompt-input"] {
  border: 3px solid var(--mw-wood) !important;
  border-radius: 12px !important;
  background-color: rgba(255, 249, 240, 0.94) !important;
  box-shadow: var(--mw-block-shadow) !important;
  margin: 6px !important;
}

.monaco-workbench .interactive-input-editor:focus-within,
.monaco-workbench [class*="chat-input"]:focus-within,
.monaco-workbench [class*="composer-input"]:focus-within {
  border-color: var(--mw-grass) !important;
  box-shadow:
    inset 0 2px 0 rgba(255, 255, 255, 0.5),
    0 0 0 2px rgba(120, 184, 51, 0.35),
    0 4px 0 rgba(90, 56, 24, 0.25) !important;
}

/* ========== Dialogs / Modals / Quick Input ========== */
.monaco-workbench .quick-input-widget {
  border: 3px solid var(--mw-wood) !important;
  border-radius: 14px !important;
  box-shadow: var(--mw-block-shadow) !important;
  overflow: hidden !important;
  background-color: rgba(255, 252, 247, 0.97) !important;
}

.monaco-workbench .quick-input-widget .quick-input-header {
  border-bottom: 2px solid rgba(120, 184, 51, 0.45) !important;
  background-image: linear-gradient(
    180deg,
    rgba(123, 200, 246, 0.25),
    rgba(255, 255, 255, 0)
  ) !important;
}

.monaco-workbench .dialog-widget,
.monaco-workbench .monaco-dialog-box,
.monaco-workbench .notification-toast-container .notification-toast {
  border: 3px solid var(--mw-wood) !important;
  border-radius: 12px !important;
  box-shadow: var(--mw-block-shadow) !important;
}

.notification-toast,
.notifications-list-container .notification-list-item {
  border-radius: 12px !important;
  border: 2px solid rgba(123, 200, 246, 0.7) !important;
  box-shadow: 0 3px 0 rgba(139, 90, 43, 0.2) !important;
}

/* Suggest / hover / context menu */
.monaco-editor .suggest-widget,
.monaco-editor .parameter-hints-widget,
.monaco-workbench .context-view .monaco-menu,
.monaco-workbench .monaco-menu-container {
  border: 2px solid rgba(139, 90, 43, 0.55) !important;
  border-radius: var(--mw-radius) !important;
  box-shadow: 0 4px 0 rgba(90, 56, 24, 0.22) !important;
  overflow: hidden !important;
}

/* ========== Inputs ========== */
.monaco-workbench .monaco-inputbox,
.monaco-workbench input.input,
.monaco-workbench .suggest-input-container {
  border: 2px solid rgba(139, 90, 43, 0.45) !important;
  border-radius: 8px !important;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.6) !important;
}

.monaco-workbench .monaco-inputbox.synthetic-focus,
.monaco-workbench .monaco-inputbox.focus {
  border-color: var(--mw-grass) !important;
}

/* ========== Scrollbars ========== */
.monaco-scrollable-element > .scrollbar > .slider {
  border-radius: 6px !important;
  border: 2px solid rgba(139, 90, 43, 0.4) !important;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.35) !important;
}

/* ========== Breadcrumbs / toolbar ========== */
.monaco-workbench .breadcrumbs-below-tabs,
.monaco-workbench .editor .breadcrumbs {
  border-bottom: 1px dashed rgba(139, 90, 43, 0.3) !important;
}

.monaco-workbench .monaco-toolbar .action-label {
  border-radius: 6px !important;
}

.monaco-workbench .monaco-toolbar .action-item:hover .action-label,
.monaco-workbench .monaco-toolbar .action-label:hover {
  box-shadow: inset 0 0 0 2px rgba(120, 184, 51, 0.45) !important;
}

/* ========== Settings editor cards ========== */
.monaco-workbench .settings-editor .setting-item,
.monaco-workbench .settings-editor .settings-group-title-label {
  border-radius: 8px !important;
}

/* ========== Welcome / empty editor ========== */
.monaco-workbench .editor-group-container.empty {
  border: 3px dashed rgba(123, 200, 246, 0.55) !important;
  border-radius: 12px !important;
}

/* Keep code crisp — never blur */
.monaco-workbench .part.editor,
.monaco-workbench .monaco-editor,
.monaco-workbench .part.auxiliarybar,
.monaco-workbench .part.sidebar,
.monaco-workbench .part.panel {
  filter: none !important;
  backdrop-filter: none !important;
}

.monaco-workbench .rendered-markdown,
.monaco-workbench .markdown-root {
  text-shadow: none !important;
  filter: none !important;
}

/* Minimap border */
.monaco-editor .minimap {
  border-left: 2px solid rgba(139, 90, 43, 0.25) !important;
}

/* Split sash accent */
.monaco-workbench .monaco-sash.vertical:before,
.monaco-workbench .monaco-sash.horizontal:before {
  background: rgba(120, 184, 51, 0.55) !important;
}


/* ---- windows.css ---- */
/* Extra window chrome: tree rows, lists, hover like game UI */
.monaco-workbench .monaco-list .monaco-list-row {
  border-radius: 6px !important;
  margin: 1px 4px !important;
}

.monaco-workbench .monaco-list .monaco-list-row.selected,
.monaco-workbench .monaco-list .monaco-list-row.focused {
  outline: 2px solid rgba(120, 184, 51, 0.55) !important;
  outline-offset: -2px !important;
}

.monaco-workbench .monaco-list .monaco-list-row:hover {
  outline: 1px solid rgba(123, 200, 246, 0.55) !important;
  outline-offset: -1px !important;
}

/* Extension / marketplace cards */
.monaco-workbench .extension-list-item,
.monaco-workbench .monaco-list .extension-list-item {
  border-radius: 10px !important;
  border: 1px solid rgba(139, 90, 43, 0.2) !important;
}

/* Find widget */
.monaco-editor .find-widget {
  border: 2px solid rgba(139, 90, 43, 0.5) !important;
  border-radius: 10px !important;
  box-shadow: 0 3px 0 rgba(90, 56, 24, 0.2) !important;
}

/* Peek view */
.monaco-editor .peekview-widget {
  border: 2px solid var(--mw-grass, #78B833) !important;
  border-radius: 10px !important;
  overflow: hidden !important;
}

/* Terminal panel chrome */
.monaco-workbench .terminal-outer-container,
.monaco-workbench .pane-body.integrated-terminal {
  border-top: 2px solid rgba(232, 140, 77, 0.35) !important;
}

/* Command center / search in title */
.monaco-workbench .command-center,
.monaco-workbench .search-viewlet,
.monaco-workbench .titlebar-center .command-center-center {
  border: 2px solid rgba(139, 90, 43, 0.4) !important;
  border-radius: 10px !important;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.5) !important;
}

/* Hover widgets */
.monaco-editor .monaco-hover {
  border: 2px solid rgba(139, 90, 43, 0.45) !important;
  border-radius: 10px !important;
  box-shadow: 0 3px 0 rgba(90, 56, 24, 0.18) !important;
}

/* Diff editor borders */
.monaco-diff-editor .diffViewport,
.monaco-diff-editor .editor.modified {
  border-left: 2px solid rgba(120, 184, 51, 0.4) !important;
}

/* Cursor-specific: agent sidebar layout containers */
.monaco-workbench [class*="agent-sidebar"],
.monaco-workbench [class*="composer-bar"],
.monaco-workbench [class*="aichat"],
.monaco-workbench .part.auxiliarybar .content {
  /* soft cream overlay so bg image stays readable */
}

.monaco-workbench .part.auxiliarybar .content > div {
  /* keep structure */
}

/* Send / action buttons in chat footer */
.monaco-workbench .part.auxiliarybar button,
.monaco-workbench [class*="composer"] button,
.monaco-workbench [class*="chat"] button {
  border-radius: 8px !important;
}


/* ---- chat.css ---- */
/* Chat / Agent immersive MiniWorld panel */
.monaco-workbench .part.auxiliarybar::before {
  content: "";
  pointer-events: none;
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6px;
  z-index: 20;
  background: linear-gradient(
    90deg,
    #78B833 0%,
    #A8D96A 25%,
    #7BC8F6 50%,
    #E88C4D 75%,
    #78B833 100%
  );
  opacity: 0.9;
}

.monaco-workbench .part.sidebar::before {
  content: "";
  pointer-events: none;
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 5px;
  z-index: 20;
  background: linear-gradient(90deg, #7BC8F6, #78B833, #E88C4D);
  opacity: 0.75;
}

/* Chat code blocks look like wooden boards */
.monaco-workbench .part.auxiliarybar pre,
.monaco-workbench .part.auxiliarybar .monaco-codeblock,
.monaco-workbench .rendered-markdown pre,
.monaco-workbench .markdown-root pre {
  border: 2px solid rgba(139, 90, 43, 0.45) !important;
  border-radius: 10px !important;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.35), 0 2px 0 rgba(90, 56, 24, 0.12) !important;
  background-color: rgba(255, 252, 247, 0.92) !important;
}

.monaco-workbench .part.auxiliarybar code,
.monaco-workbench .rendered-markdown code {
  border-radius: 4px !important;
  border: 1px solid rgba(139, 90, 43, 0.2) !important;
}

/* Sticky composer footer bar */
.monaco-workbench .part.auxiliarybar [class*="composer"] [class*="bottom"],
.monaco-workbench .part.auxiliarybar [class*="input-area"],
.monaco-workbench .part.auxiliarybar [class*="prompt-form"] {
  border-top: 2px solid rgba(139, 90, 43, 0.35) !important;
  background-color: rgba(255, 248, 235, 0.55) !important;
}

/* Mode / model picker chips */
.monaco-workbench .part.auxiliarybar [class*="chip"],
.monaco-workbench .part.auxiliarybar [class*="pill"],
.monaco-workbench .part.auxiliarybar [class*="badge"],
.monaco-workbench .part.auxiliarybar [role="button"] {
  border-radius: 8px !important;
}

/* Tree / file icons area spacing for block feel */
.monaco-workbench .explorer-folders-view .monaco-list-row {
  min-height: 24px !important;
}


/* ---- chunky-block.css ---- */
/* Button skin: chunky-block — voxel / toy-block buttons */
.monaco-workbench .monaco-button,
.monaco-workbench .monaco-text-button,
.monaco-workbench a.monaco-button,
.monaco-workbench .monaco-button-dropdown > .monaco-button,
.monaco-workbench .monaco-button-secondary,
button.monaco-text-button,
.monaco-workbench .codicon-button {
  border-radius: 10px !important;
  border: 3px solid rgba(90, 50, 20, 0.45) !important;
  box-shadow:
    inset 0 3px 0 rgba(255, 255, 255, 0.4),
    inset 0 -4px 0 rgba(0, 0, 0, 0.15),
    0 4px 0 rgba(90, 50, 20, 0.3) !important;
  font-weight: 700 !important;
  letter-spacing: 0.3px !important;
  transition: transform 0.08s ease, filter 0.08s ease !important;
  min-height: 28px !important;
}

.monaco-workbench .monaco-button:hover,
.monaco-workbench .monaco-text-button:hover,
.monaco-workbench a.monaco-button:hover {
  filter: brightness(1.08) saturate(1.08) !important;
  transform: translateY(-2px) !important;
}

.monaco-workbench .monaco-button:active,
.monaco-workbench .monaco-text-button:active {
  transform: translateY(2px) !important;
  box-shadow:
    inset 0 3px 0 rgba(0, 0, 0, 0.12),
    0 1px 0 rgba(90, 50, 20, 0.25) !important;
}

.monaco-workbench .monaco-button.secondary,
.monaco-workbench .monaco-text-button.secondary {
  border: 3px solid rgba(46, 139, 200, 0.65) !important;
}

/* Checkbox / toggle chunky look */
.monaco-workbench .monaco-custom-toggle,
.monaco-workbench .monaco-checkbox {
  border-radius: 5px !important;
  border-width: 2px !important;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4) !important;
}

/* Native-ish buttons in webviews / settings */
.monaco-workbench button:not(.monaco-button):not(.codicon):not([class*="action"]) {
  border-radius: 8px !important;
}



</style>
<!-- !! MINIWORLD-THEME-END !! -->
<!-- !! VSCODE-CUSTOM-CSS-END !! -->
</head>

